	:parameters ( ?FLOOR0 - FLOOR ?FLOOR1 - FLOOR ?FLOOR3 - FLOOR ?PASSENGER1 - PASSENGER )
	:task ( DO-BOARDED-DEPART1 ?FLOOR0 ?PASSENGER1 )
	:precondition (and  ( not ( BOARDED ?PASSENGER1 ) )  ( not ( LOCKED-LIFT-AT ?FLOOR0 )) ( not ( LIFT-AT ?FLOOR0 )) ( LIFT-AT ?FLOOR1 ) ( ABOVE ?FLOOR1 ?FLOOR3 ))
	:ordered-subtasks (and  ( UP ?FLOOR1 ?FLOOR3 ) ( ACHIEVE-LIFT-AT0 ?FLOOR0 ) ( i-LOCK-LIFT-AT ?FLOOR0 ) ( IFUNLOCK-LIFT-AT ?FLOOR0 ) ( DEPART ?FLOOR0 ?PASSENGER1 ) )
)
(:method M6-DO-BOARDED-DEPART1_gnf_3_2
	:parameters ( ?FLOOR0 - FLOOR ?FLOOR1 - FLOOR ?PASSENGER1 - PASSENGER )
	:task ( DO-BOARDED-DEPART1 ?FLOOR0 ?PASSENGER1 )
