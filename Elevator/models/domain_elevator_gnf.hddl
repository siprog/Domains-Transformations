	:ordered-subtasks (and  ( UP ?FLOOR1 ?FLOOR0 ) ( i-LOCK-LIFT-AT ?FLOOR0 ) ( IFUNLOCK-LIFT-AT ?FLOOR0 ) ( DEPART ?FLOOR0 ?PASSENGER1 ) )
)
